<%- include('head') %>
<%- include('nav', { admin }) %>
<main class="section">
  <div class="container page-head">
    <p class="eyebrow"><%= mode === 'create' ? 'Produs nou' : 'Editare produs' %></p>
    <h1><%= mode === 'create' ? 'Adauga produs in catalog' : `Actualizeaza ${product.name}` %></h1>
  </div>
  <% if (message) { %>
    <div class="container card success"><%= message %></div>
  <% } %>

  <section class="container two-col admin-form-layout">
    <form class="card form-grid" action="<%= mode === 'create' ? '/admin/produse' : `/admin/produse/${product.id}` %>" method="post" enctype="multipart/form-data">
      <label>
        Nume produs
        <input type="text" name="name" required value="<%= product?.name || '' %>" />
      </label>

      <label>
        Pret (lei)
        <input type="number" step="0.01" min="0" name="price" required value="<%= product?.price || '' %>" />
      </label>

      <label>
        Categorie
        <input type="text" name="category" required value="<%= product?.category || '' %>" />
      </label>

      <label>
        Vizibilitate
        <select name="active">
          <option value="1" <%= (product ? product.active === true : true) ? 'selected' : '' %>>Activ</option>
          <option value="0" <%= (product ? product.active === false : false) ? 'selected' : '' %>>Inactiv</option>
        </select>
      </label>

      <label>
        Tip comanda
        <select name="availability_mode" data-availability-mode>
          <option value="normal" <%= (!product || product.availability_mode !== 'preorder') ? 'selected' : '' %>>Comanda normala</option>
          <option value="preorder" <%= product?.availability_mode === 'preorder' ? 'selected' : '' %>>Precomanda (avans + rest la livrare)</option>
        </select>
      </label>

      <div class="full preorder-fields" data-preorder-fields>
        <div class="form-grid">
          <label>
            Data inceput livrare precomanda
            <input type="date" name="preorder_start_date" value="<%= product?.preorder_start_date ? new Date(product.preorder_start_date).toISOString().slice(0, 10) : '' %>" />
          </label>
          <label>
            Data final livrare precomanda
            <input type="date" name="preorder_end_date" value="<%= product?.preorder_end_date ? new Date(product.preorder_end_date).toISOString().slice(0, 10) : '' %>" />
          </label>
          <label>
            Avans (% platit acum)
            <input type="number" min="10" max="90" step="1" name="preorder_deposit_percent" value="<%= product?.availability_mode === 'preorder' ? Number(product.preorder_deposit_percent || 50) : 50 %>" />
          </label>
          <label class="full">
            Mesaj precomanda (optional)
            <input type="text" name="preorder_note" value="<%= product?.preorder_note || '' %>" placeholder="Ex: Livrare estimata in intervalul selectat." />
          </label>
        </div>
      </div>

      <label class="full">
        Descriere
        <textarea name="description" rows="5" required><%= product?.description || '' %></textarea>
      </label>

      <label class="full">
        Imagini produs (upload din calculator, poti selecta mai multe odata)
        <input type="file" name="images" accept="image/*" multiple />
        <span class="small-note">Tip: in Windows tine apasat Ctrl sau Shift cand selectezi pozele.</span>
      </label>

      <button class="btn btn-primary" type="submit"><%= mode === 'create' ? 'Salveaza produs' : 'Actualizeaza produs' %></button>
    </form>

    <aside class="card">
      <h2>Imagini existente</h2>
      <% if (!images.length) { %>
        <p>Nu exista imagini incarcate momentan.</p>
      <% } %>
      <div class="image-admin-grid">
        <% images.forEach((image) => { %>
          <article>
            <img src="<%= image.image_path %>" alt="Imagine produs" />
            <form action="/admin/imagini/<%= image.id %>/sterge" method="post" onsubmit="return confirm('Stergi aceasta imagine?');">
              <button class="btn btn-danger btn-small" type="submit">Sterge imagine</button>
            </form>
          </article>
        <% }) %>
      </div>
    </aside>
  </section>

  <% if (mode === 'edit') { %>
    <section class="container section">
      <div class="section-head">
        <p class="eyebrow">Recenzii produs</p>
        <h2>Administrare recenzii pentru acest produs</h2>
      </div>

      <div class="card">
        <h3>Adauga recenzie</h3>
        <form action="/admin/produse/<%= product.id %>/recenzii" method="post" class="form-grid">
          <label>
            Nume client
            <input type="text" name="reviewer_name" required />
          </label>
          <label>
            Email client
            <input type="email" name="reviewer_email" required />
          </label>
          <label>
            Rating
            <select name="rating" required>
              <option value="5">5</option>
              <option value="4">4</option>
              <option value="3">3</option>
              <option value="2">2</option>
              <option value="1">1</option>
            </select>
          </label>
          <label>
            Vizibilitate
            <select name="is_public">
              <option value="1">Public</option>
              <option value="0">Ascuns</option>
            </select>
          </label>
          <label class="full">
            Titlu
            <input type="text" name="title" required />
          </label>
          <label class="full">
            Mesaj
            <textarea name="message" rows="3" required></textarea>
          </label>
          <button class="btn btn-primary" type="submit">Adauga recenzie produs</button>
        </form>
      </div>

      <div class="cards-grid">
        <% if (!reviews.length) { %>
          <article class="card">
            <p>Nu exista recenzii pentru acest produs momentan.</p>
          </article>
        <% } %>
        <% reviews.forEach((review) => { %>
          <article class="card">
            <h3><%= review.title %></h3>
            <p class="small-note"><strong><%= review.reviewer_name %></strong> | <%= review.reviewer_email %></p>
            <p class="small-note">Rating: <%= review.rating %>/5 | <%= review.is_public ? 'Public' : 'Ascuns' %></p>
            <p><%= review.message %></p>
            <form action="/admin/produse/<%= product.id %>/recenzii/<%= review.id %>" method="post" class="form-grid">
              <label>
                Nume
                <input type="text" name="reviewer_name" value="<%= review.reviewer_name %>" required />
              </label>
              <label>
                Email
                <input type="email" name="reviewer_email" value="<%= review.reviewer_email %>" required />
              </label>
              <label>
                Rating
                <select name="rating">
                  <% for (let i = 5; i >= 1; i--) { %>
                    <option value="<%= i %>" <%= Number(review.rating) === i ? 'selected' : '' %>><%= i %></option>
                  <% } %>
                </select>
              </label>
              <label>
                Vizibilitate
                <select name="is_public">
                  <option value="1" <%= review.is_public ? 'selected' : '' %>>Public</option>
                  <option value="0" <%= !review.is_public ? 'selected' : '' %>>Ascuns</option>
                </select>
              </label>
              <label class="full">
                Titlu
                <input type="text" name="title" value="<%= review.title %>" required />
              </label>
              <label class="full">
                Mesaj
                <textarea name="message" rows="3" required><%= review.message %></textarea>
              </label>
              <div class="btn-mini-row">
                <button class="btn btn-secondary btn-small" type="submit">Actualizeaza</button>
              </div>
            </form>
            <form action="/admin/produse/<%= product.id %>/recenzii/<%= review.id %>/sterge" method="post" onsubmit="return confirm('Stergi recenzia?');">
              <button class="btn btn-danger btn-small" type="submit">Sterge recenzie</button>
            </form>
          </article>
        <% }) %>
      </div>
    </section>
  <% } %>
</main>
<script>
  (function () {
    const modeSelect = document.querySelector('[data-availability-mode]');
    const preorderBlock = document.querySelector('[data-preorder-fields]');
    if (!modeSelect || !preorderBlock) return;

    const dateInputs = preorderBlock.querySelectorAll('input[type="date"]');

    function syncPreorderVisibility() {
      const isPreorder = modeSelect.value === 'preorder';
      preorderBlock.classList.toggle('is-hidden', !isPreorder);
      dateInputs.forEach((input) => {
        input.required = isPreorder;
      });
    }

    modeSelect.addEventListener('change', syncPreorderVisibility);
    syncPreorderVisibility();
  })();
</script>
<%- include('footer') %>
