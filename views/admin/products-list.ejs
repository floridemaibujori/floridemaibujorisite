<%- include('head') %>
<%- include('nav', { admin }) %>
<main class="section">
  <div class="container page-head inline-head">
    <div>
      <p class="eyebrow">Produse</p>
      <h1>Administrare catalog</h1>
    </div>
    <a class="btn btn-primary" href="/admin/produse/nou">Adauga produs</a>
  </div>

  <% if (message) { %>
    <div class="container card success"><%= message %></div>
  <% } %>

  <section class="container card">
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Imagine</th>
            <th>Nume</th>
            <th>Categorie</th>
            <th>Pret</th>
            <th>Status</th>
            <th>Actiuni</th>
          </tr>
        </thead>
        <tbody>
          <% products.forEach((product) => { %>
            <tr>
              <td>
                <img class="table-thumb" src="<%= product.cover_image || '/images/placeholder-peony-1.svg' %>" alt="<%= product.name %>" />
              </td>
              <td><%= product.name %></td>
              <td><%= product.category %></td>
              <td><%= Number(product.price).toFixed(2) %> lei</td>
              <td>
                <%= product.active ? 'Activ' : 'Inactiv' %>
                <% if (product.availability_mode === 'preorder') { %>
                  <br />
                  <span class="small-note">Precomanda</span>
                <% } %>
              </td>
              <td>
                <div class="btn-mini-row">
                  <a class="btn btn-small" href="/admin/produse/<%= product.id %>/editare">Editare</a>
                  <form action="/admin/produse/<%= product.id %>/sterge" method="post" onsubmit="return confirm('Sigur vrei sa stergi produsul?');">
                    <button class="btn btn-danger btn-small" type="submit">Sterge</button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>
</main>
<%- include('footer') %>
