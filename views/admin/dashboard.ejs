<%- include('head') %>
<%- include('nav', { admin }) %>
<main class="section">
  <div class="container page-head">
    <p class="eyebrow">Dashboard</p>
    <h1>Panou administrare</h1>
  </div>

  <% if (message) { %>
    <div class="container card success"><%= message %></div>
  <% } %>

  <section class="container cards-grid metrics-grid">
    <article class="card metric-card">
      <p>Total produse</p>
      <h2><%= counts.products %></h2>
    </article>
    <article class="card metric-card">
      <p>Produse active</p>
      <h2><%= counts.activeProducts %></h2>
    </article>
    <article class="card metric-card">
      <p>Produse ascunse</p>
      <h2><%= counts.hiddenProducts %></h2>
    </article>
    <article class="card metric-card">
      <p>Total comenzi</p>
      <h2><%= counts.orders %></h2>
    </article>
    <article class="card metric-card">
      <p>Comenzi noi</p>
      <h2><%= counts.newOrders %></h2>
    </article>
  </section>

  <section class="container card">
    <h2>Schimba parola admin</h2>
    <form class="form-grid" action="/admin/schimba-parola/cod" method="post">
      <label>
        Parola curenta
        <input type="password" name="current_password" required />
      </label>
      <label>
        Parola noua
        <input type="password" name="next_password" minlength="8" required />
      </label>
      <label class="full">
        Confirma parola noua
        <input type="password" name="confirm_password" minlength="8" required />
      </label>
      <button class="btn btn-primary" type="submit">Trimite cod pe email</button>
    </form>
    <% if (passwordResetState) { %>
      <hr style="border: 0; border-top: 1px solid #ecdee3; margin: 1rem 0;" />
      <form class="form-grid" action="/admin/schimba-parola/confirma" method="post">
        <label class="full">
          Cod verificare (trimis pe floridemaibujori@gmail.com)
          <input type="text" name="verification_code" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" required />
        </label>
        <button class="btn btn-secondary" type="submit">Confirma schimbarea parolei</button>
      </form>
      <form action="/admin/schimba-parola/retrimite-cod" method="post" style="margin-top: 0.7rem;">
        <button
          class="btn btn-ghost"
          type="submit"
          data-resend-code-btn
          data-cooldown-left="<%= passwordResetCooldownLeft || 0 %>"
          <%= (passwordResetCooldownLeft || 0) > 0 ? 'disabled' : '' %>
        >
          <%= (passwordResetCooldownLeft || 0) > 0 ? `Retrimite cod in ${passwordResetCooldownLeft}s` : 'Retrimite cod' %>
        </button>
      </form>
    <% } %>
  </section>

  <section class="container card">
    <h2>Ultimele comenzi</h2>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Nr comanda</th>
            <th>Client</th>
            <th>Total</th>
            <th>Plata</th>
            <th>Status</th>
            <th>Actiuni</th>
          </tr>
        </thead>
        <tbody>
          <% if (!recentOrders.length) { %>
            <tr>
              <td colspan="6">Nu exista comenzi inregistrate momentan.</td>
            </tr>
          <% } %>
          <% recentOrders.forEach((order) => { %>
            <tr>
              <td><%= order.order_number || order.id %></td>
              <td><%= order.customer_name %></td>
              <td><%= Number(order.total_amount).toFixed(2) %> lei</td>
              <td><%= order.payment_method %> / <%= order.payment_status %></td>
              <td><span class="status-pill"><%= order.order_status %></span></td>
              <td><a class="text-link" href="/admin/comenzi/<%= order.id %>">Detalii</a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="container card">
    <h2>Ultimele produse actualizate</h2>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Nume</th>
            <th>Categorie</th>
            <th>Pret</th>
            <th>Status</th>
            <th>Actiuni</th>
          </tr>
        </thead>
        <tbody>
          <% recentProducts.forEach((p) => { %>
            <tr>
              <td><%= p.name %></td>
              <td><%= p.category %></td>
              <td><%= Number(p.price).toFixed(2) %> lei</td>
              <td><%= p.active ? 'Activ' : 'Inactiv' %></td>
              <td><a class="text-link" href="/admin/produse/<%= p.id %>/editare">Editeaza</a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>
</main>
<script>
  (function () {
    const button = document.querySelector('[data-resend-code-btn]');
    if (!button) return;

    let remaining = Number(button.dataset.cooldownLeft || 0);
    if (!Number.isFinite(remaining) || remaining <= 0) return;

    const initialText = 'Retrimite cod';
    button.disabled = true;

    const tick = function () {
      if (remaining <= 0) {
        button.disabled = false;
        button.textContent = initialText;
        return;
      }
      button.textContent = `Retrimite cod in ${remaining}s`;
      remaining -= 1;
      setTimeout(tick, 1000);
    };

    tick();
  })();
</script>
<%- include('footer') %>
