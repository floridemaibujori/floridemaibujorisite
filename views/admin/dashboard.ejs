<%- include('head') %>
<%- include('nav', { admin }) %>
<main class="section">
  <div class="container page-head">
    <p class="eyebrow">Dashboard</p>
    <h1>Panou administrare</h1>
  </div>

  <section class="container cards-grid metrics-grid">
    <article class="card metric-card">
      <p>Total produse</p>
      <h2><%= counts.products %></h2>
    </article>
    <article class="card metric-card">
      <p>Produse active</p>
      <h2><%= counts.activeProducts %></h2>
    </article>
    <article class="card metric-card">
      <p>Produse ascunse</p>
      <h2><%= counts.hiddenProducts %></h2>
    </article>
    <article class="card metric-card">
      <p>Total comenzi</p>
      <h2><%= counts.orders %></h2>
    </article>
    <article class="card metric-card">
      <p>Comenzi noi</p>
      <h2><%= counts.newOrders %></h2>
    </article>
  </section>

  <section class="container card">
    <h2>Ultimele comenzi</h2>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Nr comanda</th>
            <th>Client</th>
            <th>Total</th>
            <th>Plata</th>
            <th>Status</th>
            <th>Actiuni</th>
          </tr>
        </thead>
        <tbody>
          <% if (!recentOrders.length) { %>
            <tr>
              <td colspan="6">Nu exista comenzi inregistrate momentan.</td>
            </tr>
          <% } %>
          <% recentOrders.forEach((order) => { %>
            <tr>
              <td><%= order.order_number || order.id %></td>
              <td><%= order.customer_name %></td>
              <td><%= Number(order.total_amount).toFixed(2) %> lei</td>
              <td><%= order.payment_method %> / <%= order.payment_status %></td>
              <td><span class="status-pill"><%= order.order_status %></span></td>
              <td><a class="text-link" href="/admin/comenzi/<%= order.id %>">Detalii</a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="container card">
    <h2>Ultimele produse actualizate</h2>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Nume</th>
            <th>Categorie</th>
            <th>Pret</th>
            <th>Status</th>
            <th>Actiuni</th>
          </tr>
        </thead>
        <tbody>
          <% recentProducts.forEach((p) => { %>
            <tr>
              <td><%= p.name %></td>
              <td><%= p.category %></td>
              <td><%= Number(p.price).toFixed(2) %> lei</td>
              <td><%= p.active ? 'Activ' : 'Inactiv' %></td>
              <td><a class="text-link" href="/admin/produse/<%= p.id %>/editare">Editeaza</a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>
</main>
<%- include('footer') %>
