<%- include('head') %>
<%- include('nav', { admin }) %>
<main class="section">
  <div class="container page-head inline-head">
    <div>
      <p class="eyebrow">Comenzi</p>
      <h1>Administrare comenzi clienti</h1>
    </div>
  </div>

  <% if (message) { %>
    <div class="container card success"><%= message %></div>
  <% } %>

  <section class="container card">
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Nr comanda</th>
            <th>Data</th>
            <th>Client</th>
            <th>Telefon</th>
            <th>Produse</th>
            <th>Total</th>
            <th>Plata</th>
            <th>Status</th>
            <th>Actiuni</th>
          </tr>
        </thead>
        <tbody>
          <% if (!orders.length) { %>
            <tr>
              <td colspan="9">Nu exista comenzi inregistrate momentan.</td>
            </tr>
          <% } %>
          <% orders.forEach((order) => { %>
            <tr>
              <td><%= order.order_number || order.id %></td>
              <td><%= new Date(order.created_at).toLocaleString('ro-RO') %></td>
              <td><%= order.customer_name %></td>
              <td><%= order.customer_phone %></td>
              <td><%= order.items_count %></td>
              <td><%= Number(order.total_amount).toFixed(2) %> lei</td>
              <td><%= order.payment_method %> / <%= order.payment_status %></td>
              <td><span class="status-pill"><%= order.order_status %></span></td>
              <td><a class="btn btn-small" href="/admin/comenzi/<%= order.id %>">Detalii</a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>
</main>
<%- include('footer') %>
