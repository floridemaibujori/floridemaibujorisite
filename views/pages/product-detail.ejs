<%- include('../partials/head') %>
<%- include('../partials/header', { currentPath, company }) %>
<% const isPreorder = product.availability_mode === 'preorder'; %>
<% const depositPercent = Number(product.preorder_deposit_percent || 50); %>
<% const depositAmount = Number(product.price) * (depositPercent / 100); %>
<% const remainingAmount = Number(product.price) - depositAmount; %>
<main class="section">
  <div class="container two-col product-detail-layout">
    <div class="card image-gallery" data-image-gallery>
      <img
        class="main-image"
        data-main-image
        src="<%= (images[0] && images[0].image_path) || '/images/placeholder-peony-1.svg' %>"
        alt="<%= product.name %>"
      />
      <div class="thumb-row" data-thumb-row>
        <% images.forEach((img, index) => { %>
          <img
            src="<%= img.image_path %>"
            alt="<%= img.alt_text || product.name %>"
            data-thumb-image
            class="<%= index === 0 ? 'is-active' : '' %>"
          />
        <% }) %>
      </div>
    </div>
    <div class="card">
      <p class="category"><%= product.category %></p>
      <h1><%= product.name %></h1>
      <p class="price"><%= Number(product.price).toFixed(2) %> lei</p>
      <% if (isPreorder) { %>
        <p class="preorder-note">
          Produsul nu este in stoc acum.
          <strong><%= depositAmount.toFixed(2) %> lei acum</strong>,
          <strong><%= remainingAmount.toFixed(2) %> lei la livrare</strong>.
        </p>
        <% if (product.preorder_start_date && product.preorder_end_date) { %>
          <p class="small-note">
            Interval estimat livrare: <%= new Date(product.preorder_start_date).toLocaleDateString('ro-RO') %> - <%= new Date(product.preorder_end_date).toLocaleDateString('ro-RO') %>
          </p>
        <% } %>
        <% if (product.preorder_note) { %>
          <p class="small-note"><%= product.preorder_note %></p>
        <% } %>
      <% } %>
      <p><%= product.description %></p>
      <div class="btn-row">
        <button class="btn btn-primary" data-add-to-cart data-product-id="<%= product.id %>" data-product-name="<%= product.name %>" data-product-price="<%= product.price %>">Adauga in cos</button>
        <a class="btn btn-secondary btn-whatsapp-reserve" target="_blank" rel="noreferrer" href="<%= company.whatsappLink %>?text=Salut!%20Doresc%20sa%20rezerv%20produsul%20<%= encodeURIComponent(product.name) %>" data-notify data-notify-text="Se deschide WhatsApp pentru rezervare.">Rezerva pe WhatsApp</a>
      </div>
      <p class="small-note">Pentru comenzi speciale, suna la 0722747762.</p>
      <a class="text-link" href="/magazin">Inapoi la magazin</a>
    </div>
  </div>

  <section class="container section">
    <div class="section-head">
      <p class="eyebrow">Produse similare</p>
      <h2>Din aceeasi categorie</h2>
    </div>
    <div class="cards-grid">
      <% related.forEach((item) => { %>
        <article class="product-card card" data-product-card data-product-url="/magazin/produs/<%= item.id %>" tabindex="0" role="link" aria-label="Deschide produsul <%= item.name %>">
          <img src="<%= item.cover_image || '/images/placeholder-peony-2.svg' %>" alt="<%= item.name %>" />
          <h3><%= item.name %></h3>
          <p><%= item.description %></p>
          <div class="btn-mini-row">
            <button class="btn btn-small" data-add-to-cart data-product-id="<%= item.id %>" data-product-name="<%= item.name %>" data-product-price="<%= item.price %>">Adauga in cos</button>
            <a class="btn btn-ghost btn-small btn-whatsapp-reserve" target="_blank" rel="noreferrer" href="<%= company.whatsappLink %>?text=Salut!%20Doresc%20sa%20rezerv%20produsul%20<%= encodeURIComponent(item.name) %>" data-notify data-notify-text="Se deschide WhatsApp pentru rezervare.">Rezerva pe WhatsApp</a>
          </div>
        </article>
      <% }) %>
    </div>
  </section>

  <section class="container section section-soft">
    <div class="section-head">
      <p class="eyebrow">Recenzii produs</p>
      <h2>Ce spun clientii despre <%= product.name %></h2>
      <p class="lead">
        Rating mediu:
        <strong><%= productReviewData.summary.avgRating ? productReviewData.summary.avgRating.toFixed(1) : '0.0' %>/5</strong>
        din <strong><%= productReviewData.summary.totalCount %></strong> recenzii.
      </p>
    </div>

    <div class="cards-grid">
      <% if (!productReviewData.reviews.length) { %>
        <article class="card quote-card">
          <p>Nu exista recenzii pentru acest produs momentan.</p>
        </article>
      <% } %>
      <% productReviewData.reviews.forEach((review) => { %>
        <article class="card quote-card premium-review-card">
          <div class="stars" aria-label="Rating <%= review.rating %> din 5">
            <% for (let i = 1; i <= 5; i++) { %>
              <span class="<%= i <= review.rating ? 'star-on' : 'star-off' %>">&#9733;</span>
            <% } %>
          </div>
          <h3><%= review.title %></h3>
          <p>"<%= review.message %>"</p>
          <strong><%= review.reviewer_name %></strong>
        </article>
      <% }) %>
    </div>

    <div class="card review-form-card">
      <h3>Lasa recenzia pentru acest produs</h3>
      <p class="small-note">Emailul trebuie sa existe intr-o comanda care include acest produs.</p>
      <form class="form-grid" data-review-form data-review-type="product" data-product-id="<%= product.id %>">
        <label>
          Nume
          <input type="text" name="reviewerName" required />
        </label>
        <label>
          Email comanda
          <input type="email" name="reviewerEmail" required />
        </label>
        <label>
          Rating
          <select name="rating" required>
            <option value="">Alege</option>
            <option value="5">5 stele</option>
            <option value="4">4 stele</option>
            <option value="3">3 stele</option>
            <option value="2">2 stele</option>
            <option value="1">1 stea</option>
          </select>
        </label>
        <label>
          Titlu recenzie
          <input type="text" name="title" required />
        </label>
        <label class="full">
          Mesaj
          <textarea name="message" rows="4" required></textarea>
        </label>
        <button class="btn btn-primary" type="submit">Trimite recenzie</button>
      </form>
    </div>
  </section>
</main>
<%- include('../partials/footer', { company }) %>


